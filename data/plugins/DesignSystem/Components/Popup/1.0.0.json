{
  "name": "Popup",
  "version": "1.0.0",
  "slug": "popup",
  "category": "component",
  "description": "A draggable pop-up window component.",
  "author": "SuperApps Team",
  "exports": {
    "logic": {
      "path": "Popup.js",
      "format": "esm"
    },
    "template": {
      "path": "Popup.html",
      "format": "html"
    },
    "styles": [
      { "path": "Popup.css", "scope": "global" }
    ]
  },
  "variants": {
    "mode": "stack",
    "defaults": ["default"],
    "available": ["default", "fullscreen", "minimal"]
  }
}
