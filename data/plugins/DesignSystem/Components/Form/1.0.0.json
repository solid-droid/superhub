{
  "name": "Form",
  "version": "1.0.0",
  "slug": "form",
  "category": "component",
  "description": "A validation-enabled input form container component.",
  "author": "SuperApps Team",
  "exports": {
    "logic": {
      "path": "Form.js",
      "format": "esm"
    },
    "template": {
      "path": "Form.html",
      "format": "html"
    },
    "styles": [
      { "path": "Form.css", "scope": "global" }
    ]
  },
  "variants": {
    "mode": "stack",
    "defaults": ["default"],
    "available": ["default", "compact", "inline"]
  }
}
