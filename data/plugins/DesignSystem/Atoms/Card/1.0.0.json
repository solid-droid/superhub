{
  "name": "Card",
  "version": "1.0.0",
  "slug": "card",
  "category": "atom",
  "description": "A reusable container card component.",
  "author": "SuperApps Team",
  "exports": {
    "logic": {
      "path": "Card.js",
      "format": "esm"
    },
    "template": {
      "path": "Card.html",
      "format": "html"
    },
    "styles": [
      { "path": "Card.css", "scope": "global" }
    ]
  },
  "variants": {
    "mode": "stack",
    "defaults": ["elevated"],
    "available": ["elevated", "outlined", "flat"]
  }
}
