{
  "name": "TextInput",
  "version": "1.0.0",
  "slug": "input",
  "category": "atom",
  "description": "A reusable text input field component.",
  "author": "SuperApps Team",
  "exports": {
    "logic": {
      "path": "Input.js",
      "format": "esm"
    },
    "template": {
      "path": "Input.html",
      "format": "html"
    },
    "styles": [
      { "path": "Input.css", "scope": "global" }
    ]
  },
  "variants": {
    "mode": "stack",
    "defaults": ["outlined"],
    "available": ["outlined", "filled"]
  }
}
