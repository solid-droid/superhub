{
  "name": "Button",
  "version": "1.0.0",
  "slug": "button",
  "category": "atom",
  "description": "A reusable button component.",
  "author": "SuperApps Team",
  "exports": {
    "logic": {
      "path": "Button.js",
      "format": "esm"
    },
    "template": {
      "path": "Button.html",
      "format": "html"
    },
    "styles": [
      { "path": "Button.css", "scope": "global" }
    ]
  },
  "variants": {
    "mode": "stack",
    "defaults": ["primary"],
    "available": ["primary", "secondary", "tertiary", "icon", "icon-label"],
    "groups": {
      "style": ["primary", "secondary", "tertiary", "icon", "icon-label"]
    }
  }
}