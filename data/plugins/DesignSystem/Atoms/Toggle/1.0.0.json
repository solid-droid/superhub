{
  "name": "Toggle",
  "version": "1.0.0",
  "slug": "toggle",
  "category": "atom",
  "description": "A switch-style toggle control.",
  "author": "SuperApps Team",
  "exports": {
    "logic": { "path": "Toggle.js", "format": "esm" },
    "template": { "path": "Toggle.html", "format": "html" },
    "styles": [{ "path": "Toggle.css", "scope": "global" }]
  },
  "variants": {
    "mode": "stack",
    "defaults": ["default"],
    "available": ["default", "success"],
    "groups": {
      "tone": ["default", "success"]
    },
    "conflictPolicy": "last-write-wins"
  }
}
