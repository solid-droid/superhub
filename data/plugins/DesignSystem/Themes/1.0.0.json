{
  "name": "Theme",
  "version": "1.0.0",
  "slug": "theme",
  "category": "theme",
  "description": "Theme manager supporting light, dark color bases and retro, glass, modern aesthetic modifiers.",
  "author": "SuperApps Team",
  "exports": {
    "logic": {
      "path": "Theme.js",
      "format": "esm"
    },
    "template": null,
    "styles": [
      { "path": "dark.css", "scope": "global" },
      { "path": "light.css", "scope": "global" },
      { "path": "high-contrast.css", "scope": "global" },
      { "path": "retro.css", "scope": "global" },
      { "path": "glass.css", "scope": "global" },
      { "path": "modern.css", "scope": "global" },
      { "path": "minimal.css", "scope": "global" },
      { "path": "neobrutalist.css", "scope": "global" }
    ]
  },
  "variants": {
    "mode": "stack",
    "defaults": ["dark", "modern"],
    "available": ["dark", "light", "high-contrast", "retro", "glass", "modern", "minimal", "neobrutalist"],
    "groups": {
      "base": ["dark", "light", "high-contrast"],
      "style": ["modern", "glass", "retro", "minimal", "neobrutalist"]
    },
    "conflictPolicy": "resolver",
    "resolver": {
      "order": ["high-contrast", "dark", "light", "neobrutalist", "minimal", "glass", "retro", "modern"]
    }
  }
}
