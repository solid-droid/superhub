{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plugin Metadata Schema v2",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The human-readable name of the plugin."
    },
    "version": {
      "type": "string",
      "description": "The semantic version of the plugin."
    },
    "description": {
      "type": "string",
      "description": "A brief description of what the plugin does."
    },
    "author": {
      "type": "string",
      "description": "The author of the plugin."
    },
    "slug": {
      "type": "string",
      "description": "Unique plugin slug."
    },
    "category": {
      "type": "string",
      "enum": ["atom", "component", "theme", "application", "data"],
      "description": "Plugin category."
    },
    "exports": {
      "type": "object",
      "required": ["logic"],
      "properties": {
        "logic": {
          "type": "object",
          "required": ["path"],
          "properties": {
            "path": { "type": "string" },
            "format": { "type": "string" }
          }
        },
        "template": {
          "type": ["object", "null"],
          "properties": {
            "path": { "type": "string" },
            "format": { "type": "string" }
          }
        },
        "styles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "scope": { "type": "string" }
            }
          }
        }
      }
    },
    "variants": {
      "type": "object",
      "properties": {
        "defaults": {
          "type": "array",
          "items": { "type": "string" }
        },
        "available": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mode": {
          "type": "string",
          "enum": ["stack"]
        },
        "groups": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "conflictPolicy": {
          "type": "string",
          "enum": ["strict", "resolver", "last-write-wins"]
        },
        "resolver": {
          "type": "object",
          "properties": {
            "order": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "required": ["name", "version", "slug", "category", "exports"]
}